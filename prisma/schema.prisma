generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["db_growtwitter_schemas"]
}

model Usuario {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome         String   @db.VarChar(120)
  username     String   @unique @db.VarChar(120)
  email        String   @unique @db.VarChar(60)
  senha        String
  dtNascimento DateTime @map("dt_nascimento") @db.Date
  fotoPerfil   String?  @map("foto_perfil")

  dtCriacao DateTime @default(now()) @map("dt_criacao")
  dtUpdate  DateTime @updatedAt @map("dt_update")

  tweets    Tweet[]
  // QuemMeSegue
  followers Follow[] @relation("QuemMeSegue")
  //QuemEuSigo
  following Follow[] @relation("QuemEuSigo")

  likes    Like[]    @relation("UsuariosId")
  comments Comment[]

  @@map("usuario")
  @@schema("db_growtwitter_schemas")
}

model Tweet {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conteudo  String   @db.VarChar(280)
  dtCriacao DateTime @default(now()) @map("dt_criacao")
  dtUpdate  DateTime @updatedAt @map("dt_update")
  fotoTweet String? @map("foto_tweet")

  //guarda o id do tweet pai referenciado
  replyId String? @map("reply_id") @db.Uuid
  // replyTo é um novo tweet que aponta para o "Tweet-Pai"
  replyTo Tweet?  @relation("TweetReplies", fields: [replyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // apontando a relacao | replies representa uma lista de tweets "filhos"
  replies Tweet[] @relation("TweetReplies")

  userId  String  @map("user_id") @db.Uuid
  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  likes    Like[]    @relation("TweetsLiked")
  comments Comment[]

  @@map("tweet")
  @@schema("db_growtwitter_schemas")
}

model Like {
  usuarioId String @map("usuario_id") @db.Uuid //quem curtiu
  tweetId   String @map("tweet_id") @db.Uuid // tweet curtido

  dtCriacao DateTime @default(now()) @map("dt_criacao")
  dtUpdate  DateTime @updatedAt @map("dt_update")

  usuario Usuario @relation("UsuariosId", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: Cascade) // quem curtiu
  tweet   Tweet   @relation("TweetsLiked", fields: [tweetId], references: [id], onDelete: Cascade, onUpdate: Cascade) // tweet curtido

  @@id([usuarioId, tweetId])
  @@map("like")
  @@schema("db_growtwitter_schemas")
}

model Follow {
  followerId  String @map("follower_id") @db.Uuid // seguir
  followingId String @map("following_id") @db.Uuid // seguindo

  dtCriacao DateTime @default(now()) @map("dt_criacao")
  dtUpdate  DateTime @updatedAt @map("dt_update")

  follower  Usuario @relation("QuemEuSigo", fields: [followerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  following Usuario @relation("QuemMeSegue", fields: [followingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([followerId, followingId])
  @@map("follow")
  @@schema("db_growtwitter_schemas")
}

model Comment {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conteudo String @db.VarChar(280)

  userId  String @map("user_id") @db.Uuid
  tweetId String @map("tweet_id") @db.Uuid

  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet   Tweet   @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  dtCriacao DateTime @default(now()) @map("dt_criacao")
  dtUpdate  DateTime @updatedAt @map("dt_update")

  @@map("comment")
  @@schema("db_growtwitter_schemas")
}
